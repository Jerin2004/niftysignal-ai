# NiftySignal AI - Environment Configuration
# Copy this file to .env and fill in your actual keys

# NewsAPI - Get free key at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Zerodha Kite API - Get from https://developers.kite.trade
# Personal plan is free - go to developers.kite.trade and create app
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here

# Server config
PORT=8000
